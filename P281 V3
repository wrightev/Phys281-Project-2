def plot_projection(x, y, z, title="",xlabel="",ylabel=""):
    plt.figure(figsize=(6,6))
    plt.hist2d(x, y, bins=100)
    plt.title(title)
    plt.xlabel(xlabel)
    plt.ylabel(ylabel)
    plt.axis("equal")
    plt.show()

def density_profile(r, bins=50):
    hist, edges = np.histogram(r, bins=bins)
    centers = 0.5*(edges[1:] + edges[:-1])
    vol = (4/3)*np.pi*(edges[1:]**3 - edges[:-1]**3)
    rho = hist / vol

    plt.loglog(centers, rho, 'o')
    plt.xlabel("r (kpc)")
    plt.ylabel("Radial Density (M/kpc^3)")
    plt.show()

def density_disk(r, bins=50):
    hist, edges = np.histogram(r, bins=bins)
    centers = 0.5*(edges[1:] + edges[:-1])
    area = (4)*np.pi*(edges[1:]**2 - edges[:-1]**2)
    sigma = hist / area

    plt.loglog(centers, sigma, 'o')
    plt.xlabel("r (kpc)")
    plt.ylabel("Surface Density (M/kpc^2)")
    plt.show()

