def spherical_to_cartesian(r, theta, phi):
    x = r * np.cos(theta) * np.cos(phi)
    y = r * np.cos(theta) * np.sin(phi)
    z = r * np.sin(theta)
    return x, y, z

def cylindrical_to_cartesian(r, theta, z):
    x = r * np.cos(theta)
    y = r * np.sin(theta)
    return x, y, z

def phi_isotherm(r):
    return G*np.log(r)

def make_isothermal():
    r = RS.rand(N)

    cos_theta = 2*RS.rand(N) - 1
    theta = np.arcsin(cos_theta)
    phi = 2*np.pi*RS.rand(N)

    x, y, z = spherical_to_cartesian(r, theta, phi)

    rho0 = 1/(4*np.pi)  # from M(1)=1
    vc = np.sqrt(4*np.pi*G*rho0)

    sigma = vc / np.sqrt(3)

    vx = RS.randn(N) * sigma
    vy = RS.randn(N) * sigma
    vz = RS.randn(N) * sigma

    W = np.sum(phi_isotherm(r))
    vi2 = (vx**2) + (vy**2) + (vz**2)
    T = np.sum(vi2)
    E = T/np.abs(W)
    print(E)

    return x, y, z, vx, vy, vz, r

c = 15

def rho_nfw(r):
    rho0 = (c**3)/(4*np.pi*(np.log(1+c)-c/(1+c)))
    return rho0 / (c*r*(1+c*r)**2)

def sample_nfw():
    r_vals = []
    while len(r_vals) < N:
        xrand = RS.rand(N)
        yrand = RS.rand(N)

        f = 4*np.pi*xrand**2 * rho_nfw(xrand)
        fmax = np.max(f)

        keep = yrand < f/fmax
        r_vals.extend(xrand[keep])

    return np.array(r_vals[:N])

def phi_nfw(r): #NFW potential fn
    rho0 = (c**3)/(4*np.pi*(np.log(1+c)-c/(1+c)))
    return -(4*np.pi*rho0/(c**3)) * (np.log(1+c*r)/r)

def make_nfw():
    r = sample_nfw()

    cos_theta = 2*RS.rand(N) - 1
    theta = np.arcsin(cos_theta)
    phi = 2*np.pi*RS.rand(N)

    x, y, z = spherical_to_cartesian(r, theta, phi)

    #load dispersion table
    data = np.loadtxt("NFW_dispersion.dat")
    interp_sigma = interp1d(data[:,0], data[:,1], fill_value="extrapolate")

    sigma = interp_sigma(r)

    vx = RS.randn(N)*sigma
    vy = RS.randn(N)*sigma
    vz = RS.randn(N)*sigma

    W_nfw = np.sum(phi_nfw(r))
    vi2_nfw = (vx**2) + (vy**2) + (vz**2)
    T_nfw = np.sum(vi2_nfw)
    E = T_nfw/np.abs(W_nfw)
    print(E)

    return x, y, z, vx, vy, vz, r

def M_nfw(r):
    rho0 = (c**3)/(4*np.pi*(np.log(1+c)-c/(1+c)))
    return 4*np.pi*rho0/(c**3) * (np.log(1+c*r) - (c*r)/(1+c*r))

def vc_nfw(r):
    return np.sqrt(G * M_nfw(r) / r)

def sigma_disk(r):
    return (M_disk/(2*np.pi*R_disk**2)) * np.exp(-r/R_disk)

def sample_disk_r():
    r_vals = []
    while len(r_vals) < N:
        xrand = RS.rand(N)
        yrand = RS.rand(N)

        f = 2*np.pi*xrand*sigma_disk(xrand)
        fmax = np.max(f)

        keep = yrand < f/fmax
        r_vals.extend(xrand[keep])

    return np.array(r_vals[:N])

def phi_disk(r): #Exponential disk potential fn
    a = 2*R_disk
    return (M_disk/(R_disk*a))*(special.i1(r/a)*special.k0(r/a) - special.i0(r/a)*special.k1(r/a))

