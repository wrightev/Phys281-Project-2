def vc_disk(r):
    x = r/(2*R_disk)
    return np.sqrt((G*M_disk/(2*R_disk)) * r**2 *
                   (special.i0(x)*special.k0(x) - special.i1(x)*special.k1(x)))

def vc_total(r):
    return np.sqrt(vc_nfw(r)**2 + vc_disk(r)**2)

