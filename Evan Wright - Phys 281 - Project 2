#Coordinate transforms
def c_sphere(x,y,z):
    r = np.sqrt((x**2) + (y**2) + (z**2))
    theta = np.asin(z/r)
    phi = np.acos(x/(r*np.cos(theta)))
    return (r,theta, phi)
def s_cart(r,theta,phi):
    x = r*np.cos(theta)*np.cos(phi)
    y = r*np.cos(theta)*np.sin(phi)
    z = r*np.sin(theta)
    return x,y,z
def c_cylind(x,y,z):
    r = np.sqrt((x**2) + (y**2) + (z**2))
    theta = np.acos(x/r)
    z = z
    return(r,theta,z)
def c_cart(r,theta,z):
    x = r*np.cos(theta)
    y = r*np.sin(theta+(np.pi/2))
    z = z
    return(x,y,z)

