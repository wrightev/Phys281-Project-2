#NFW model, once again in spherical coordinates
#Radial distribution: R_vir = 1, M(R_vir) = 1, c = R_vir/r_s
def nfw_dist(r):
    p0 = ((c**3)/(4*np.pi))*((np.log(1+c) - (c/(1+c)))**(-1))
    p = p0/(c*r*((1+(c*r))**2))
    return p #returns density inside radius r
